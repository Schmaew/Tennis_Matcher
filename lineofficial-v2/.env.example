# Tennis Matcher Bot v2 — Environment Variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- LINE ---
# developers.line.biz -> your channel -> Basic settings
LINE_CHANNEL_SECRET=

# developers.line.biz -> your channel -> Messaging API tab -> Issue
LINE_CHANNEL_ACCESS_TOKEN=

# --- Supabase ---
# Supabase dashboard -> Settings -> API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=

# --- Admin dashboard ---
# Random secret used to log into /admin (Bearer token).
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
ADMIN_TOKEN=

# Optional. If set, the admin page moves from /admin to /<this>/admin.
# Same defense-in-depth pattern as the senior's repo.
ADMIN_PATH_SECRET=

PORT=5001
