# ─────────────────────────────────────────────────────────────────────────────
# Tennis Matcher – Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git (it is already in .gitignore).
#
# How to get a Google Places API key:
#   1. Go to https://console.cloud.google.com/
#   2. Create a new project (or select an existing one)
#   3. Enable the "Places API" from APIs & Services → Library
#   4. Go to APIs & Services → Credentials → Create Credentials → API Key
#   5. (Recommended) Restrict the key to "Places API" only
#   6. Paste the key below
#
# In Expo, any variable prefixed with EXPO_PUBLIC_ is bundled into the app
# and accessible via process.env.EXPO_PUBLIC_*
# ─────────────────────────────────────────────────────────────────────────────

EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=YOUR_API_KEY_HERE

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (used by the Courts tab to load real Thailand court data)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Open your Supabase project → Settings → API
# 2. Copy the "Project URL" into EXPO_PUBLIC_SUPABASE_URL
# 3. Copy the "anon public" key into EXPO_PUBLIC_SUPABASE_ANON_KEY
#    (use the anon key, NOT the service_role key — service_role must never be
#     bundled into a mobile app)
# ─────────────────────────────────────────────────────────────────────────────

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
